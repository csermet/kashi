# Copy to .env and fill in. Both values are secrets — never commit .env.
POSTGRES_PASSWORD=change-me
# Format: ksh_ + 32 hex chars. Generate with: echo "ksh_$(openssl rand -hex 16)"
ADMIN_API_KEY=ksh_00000000000000000000000000000000
# off | second_pass | always  (htdemucs vocal separation)
SEPARATION_MODE=off
# Optional bgutil PoToken provider (compose --profile pot): http://bgutil:4416
BGUTIL_POT_PROVIDER_URL=
